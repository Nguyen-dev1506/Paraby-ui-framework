window(
    size: 350, 300
    title: My first app by paraby
    
    loop(
        # Cách 1: Gán biến trực tiếp
        my_entry = entry(
            place: top
            text: Nhập tên của bạn...
            input: user_name
        )

        # Cách 2: Sử dụng thuộc tính name
        btn(
            name: my_btn
            place: center
            color: gray
            text: Click me
        )

        my_label = lable(
            place: bottom
            text: Chưa nhận tên
            font: Courier
            font_size: 18
            type: bold
            color: red
        )

        my_slider = slider(
            place: bottom
            from: 0
            to: 100
            input: slider_val
        )

        my_tick = tick(
            place: bottom
            text: Đồng ý điều khoản
            input: tick_status
        )

        my_progress = progress(
            place: bottom
            color: green
        )
    )
)
